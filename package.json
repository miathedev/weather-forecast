{
  "name": "weather-forecast",
  "type": "module",
  "version": "0.0.1",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node -e \"process.argv = [process.argv[0], 'node_modules/astro/bin/astro.mjs', ...process.argv.slice(1)]; Object.defineProperty(process.versions, 'node', { value: '22.12.0' }); import('./node_modules/astro/bin/astro.mjs')\" -- dev --host",
    "build": "node -e \"process.argv = [process.argv[0], 'node_modules/astro/bin/astro.mjs', ...process.argv.slice(1)]; Object.defineProperty(process.versions, 'node', { value: '22.12.0' }); import('./node_modules/astro/bin/astro.mjs')\" -- build",
    "preview": "node -e \"process.argv = [process.argv[0], 'node_modules/astro/bin/astro.mjs', ...process.argv.slice(1)]; Object.defineProperty(process.versions, 'node', { value: '22.12.0' }); import('./node_modules/astro/bin/astro.mjs')\" -- preview",
    "astro": "node -e \"process.argv = [process.argv[0], 'node_modules/astro/bin/astro.mjs', ...process.argv.slice(1)]; Object.defineProperty(process.versions, 'node', { value: '22.12.0' }); import('./node_modules/astro/bin/astro.mjs')\" --",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder",
    "start": "NODE_ENV=production electron ."
  },
  "dependencies": {
    "@astrojs/node": "^10.0.6",
    "@astrojs/react": "^5.0.2",
    "@tabler/icons-react": "^3.41.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.10",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.weather.forecast",
    "productName": "WeatherForecast",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "tsconfig.json",
      "public/**/*",
      ".env"
    ],
    "asar": false,
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
